<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane fx:id="rootForgotPane" prefHeight="480.0" prefWidth="450.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.ForgotPasswordFormController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="35.0" left="40.0" right="40.0" top="35.0" />
            </padding>
            <children>

                <VBox alignment="CENTER" spacing="6.0">
                    <children>
                        <VBox alignment="CENTER" minHeight="50.0" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #FEF2F2; -fx-background-radius: 50%;">
                            <children>
                                <FontIcon iconColor="#EF4444" iconLiteral="fas-key" iconSize="22" />
                            </children>
                        </VBox>
                        <Label text="Recover Password" textFill="#1E293B">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label text="Provide account details along with your unique recovery keyword phrase to authorize an instant credential reset." textAlignment="CENTER" textFill="#64748B" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Account Username" textFill="#475569" />
                                <TextField fx:id="txtUsername" prefHeight="38.0" promptText="lasandi99" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Registered Email Address" textFill="#475569" />
                                <TextField fx:id="txtEmail" prefHeight="38.0" promptText="lasandi@theserenity.com" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Your Secret Recovery Keyword" textFill="#475569" />
                                <TextField fx:id="txtKeyword" prefHeight="38.0" promptText="Enter security secret key" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Button fx:id="btnRecover" maxWidth="Infinity" onAction="#btnRecoverOnAction" prefHeight="42.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 6px; -fx-cursor: hand;" text="Verify &amp; Reset Password" />

                <HBox alignment="CENTER" spacing="4.0">
                    <children>
                        <Label style="-fx-font-size: 12px;" text="Remembered credentials?" textFill="#64748B" />
                        <Hyperlink fx:id="lnkBackToLogin" onAction="#lnkBackToLoginOnAction" style="-fx-font-weight: bold; -fx-text-fill: #EF4444; -fx-underline: false; -fx-font-size: 12px;" text="Back to Login" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>