<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.Double?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="625.0" prefWidth="1020.0" styleClass="content-canvas" stylesheets="@../css/therapist.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.PaymentFormController">
    <children>
        <VBox spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="2.0" prefWidth="980.0" styleClass="filter-bar">
                    <children>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Label fx:id="lblSelectedCount" styleClass="field-label" text="0 entries selected for communication" />
                                <Label styleClass="field-label" text="|" />
                                <Label fx:id="lblTotalRecords" styleClass="field-label" text="Total Records: 0" />
                            </children>
                        </HBox>
                    </children>
                    <padding><Insets left="12.0" right="12.0" /></padding>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="38.0" spacing="10.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                            <children>
                                <FontIcon iconColor="#64748B" iconLiteral="fas-search" iconSize="14" />
                                <TextField fx:id="txtSearchPayments" onKeyReleased="#txtSearchPaymentsOnKeyReleased" prefHeight="36.0" promptText="Search transactions by invoice code, patient name, or specialist lookup..." styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                            </children>
                            <padding><Insets left="12.0" right="12.0" /></padding>
                        </HBox>

                        <ComboBox fx:id="cmbProgramFilter" prefHeight="38.0" prefWidth="180.0" promptText="All Programs" styleClass="text-field-raw">
                            <maxWidth><Double fx:constant="MAX_VALUE" /></maxWidth>
                        </ComboBox>

                        <ComboBox fx:id="cmbPaymentStatusFilter" prefHeight="38.0" prefWidth="180.0" promptText="All Statuses" styleClass="text-field-raw">
                            <maxWidth><Double fx:constant="MAX_VALUE" /></maxWidth>
                        </ComboBox>
                    </children>
                </HBox>

                <AnchorPane prefHeight="570.0" prefWidth="980.0" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="tblPayment" layoutY="0.8" onMouseClicked="#tblPaymentOnMouseClicked" prefHeight="427.0" prefWidth="980.0" styleClass="clinical-table" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="1.0">
                            <columns>
                                <TableColumn fx:id="colSelect" maxWidth="45.0" minWidth="45.0" prefWidth="45.0" resizable="false" text="✔" />
                                <TableColumn fx:id="colInvoiceNo" prefWidth="100.0" text="Invoice ID" />
                                <TableColumn fx:id="colPatientName" prefWidth="180.0" text="Patient Profile" />
                                <TableColumn fx:id="colProgramName" prefWidth="180.0" text="Treatment Program" />
                                <TableColumn fx:id="colTherapistName" prefWidth="160.0" text="Assigned Specialist" />
                                <TableColumn fx:id="colDate" prefWidth="110.0" text="Settle Date" />
                                <TableColumn fx:id="colAmount" prefWidth="110.0" text="Gross Revenue" />
                                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Payment Status" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnRefresh" onAction="#btnRefreshOnAction" prefHeight="38.0" prefWidth="50.0" styleClass="btn-clear">
                            <graphic>
                                <FontIcon iconColor="#475569" iconLiteral="fas-sync-alt" iconSize="13" />
                            </graphic>
                        </Button>
                        <Button fx:id="btnDeselectAll" onAction="#btnDeselectAllOnAction" prefHeight="38.0" prefWidth="120.0" styleClass="btn-delete" text="Deselect All" />
                        <Button fx:id="btnSelectAll" onAction="#btnSelectAllOnAction" prefHeight="38.0" prefWidth="120.0" styleClass="btn-clear" text="Select Filtered" />

                        <HBox HBox.hgrow="ALWAYS" /> <Button fx:id="btnSendNotification" onAction="#btnSendNotificationOnAction" prefHeight="38.0" prefWidth="250.0" styleClass="btn-save" text="Send Custom Notification">
                        <graphic>
                            <FontIcon iconColor="#FFFFFF" iconLiteral="fas-comment-alt" iconSize="13" />
                        </graphic>
                    </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
