<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="625.0" prefWidth="1020.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.ProfileFormController">
    <children>
        <VBox layoutX="50.0" layoutY="40.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 30; -fx-background-radius: 8px; -fx-border-color: #E2E8F0; -fx-border-radius: 8px;">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Security Credentials Settings" textFill="#1E293B">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label text="Update your username and cryptographic access passwords securely." textFill="#64748B" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="12.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Active Username" textFill="#475569" />
                                <TextField fx:id="txtUsername" prefHeight="38.0" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px;" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="New Security Password" textFill="#475569" />
                                <PasswordField fx:id="txtNewPassword" prefHeight="38.0" promptText="Enter fresh password" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px;" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Confirm Password" textFill="#475569" />
                                <PasswordField fx:id="txtConfirmPassword" prefHeight="38.0" promptText="Retype fresh password" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Button fx:id="btnSave" maxWidth="Infinity" onAction="#btnSaveOnAction" prefHeight="40.0" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;" text="Update Profile Credentials">
                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-save" iconSize="12" />
                    </graphic>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>