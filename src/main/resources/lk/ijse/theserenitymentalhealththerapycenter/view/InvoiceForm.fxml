<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane prefHeight="625.0" prefWidth="1020.0" styleClass="content-canvas" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.InvoiceFormController">
    <children>
        <VBox spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="45.0" spacing="15.0" styleClass="filter-bar">
                    <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="990.0" prefHeight="46.0" prefWidth="990.0" spacing="10.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                            <children>
                                <FontIcon iconColor="#64748B" iconLiteral="fas-search" iconSize="14" />
                                <TextField fx:id="txtSearchInvoice" prefHeight="37.0" prefWidth="500.0" promptText="Filter invoice ledger history logs by tracking number..." styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                            </children>
                            <padding><Insets left="12.0" right="12.0" /></padding>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="15.0" styleClass="form-card">
                    <children>
                        <GridPane hgap="15.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25.0" />
                                <ColumnConstraints percentWidth="25.0" />
                                <ColumnConstraints percentWidth="25.0" />
                                <ColumnConstraints percentWidth="25.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="65.0" />
                            </rowConstraints>
                            <children>
                                <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="field-label" text="Select Patient *" />
                                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                                            <children>
                                                <FontIcon iconColor="#94A3B8" iconLiteral="fas-user" iconSize="14" />
                                                <ComboBox fx:id="cmbPatient" maxWidth="Infinity" prefHeight="38.0" promptText="Choose Patient Profile" styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="field-label" text="Select Therapy Program *" />
                                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                                            <children>
                                                <FontIcon iconColor="#94A3B8" iconLiteral="fas-brain" iconSize="14" />
                                                <ComboBox fx:id="cmbProgram" maxWidth="Infinity" prefHeight="38.0" promptText="Choose Framework" styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="field-label" text="Payment Amount (LKR) *" />
                                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                                            <children>
                                                <FontIcon iconColor="#64748B" iconLiteral="fas-money-bill-wave" iconSize="14" />
                                                <TextField fx:id="txtAmount" prefHeight="38.0" promptText="0.00" styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="field-label" text="Current Outstanding Balance" />
                                        <HBox alignment="CENTER_LEFT" styleClass="input-box" fx:id="boxBalanceContainer" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6px;">
                                            <children>
                                                <FontIcon fx:id="iconBalanceStatus" iconColor="#64748B" iconLiteral="fas-exclamation-circle" iconSize="14" />
                                                <TextField fx:id="txtOutstandingBalance" editable="false" prefHeight="38.0" text="LKR 0.00" styleClass="text-field-raw" style="-fx-text-fill: #64748B; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button fx:id="btnClear" onAction="#btnClearOnAction" prefHeight="38.0" prefWidth="120.0" styleClass="btn-clear" text="Clear Form" />
                                <Button fx:id="btnPayPrint" onAction="#btnPayPrintOnAction" prefHeight="38.0" prefWidth="220.0" styleClass="btn-save" text="💳 Process &amp; Print" />
                            </children>
                        </HBox>
                    </children>
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                </VBox>

                <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox prefWidth="640.0" spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 13px;" text="📜 General Transaction Ledger Logs" />
                                <AnchorPane VBox.vgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="tblPayments" styleClass="clinical-table" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                            <columns>
                                                <TableColumn fx:id="colInvoiceNo" prefWidth="120.0" text="Invoice Number" />
                                                <TableColumn fx:id="colPatient" prefWidth="180.0" text="Full Patient Name" />
                                                <TableColumn fx:id="colProgram" prefWidth="190.0" text="Assigned Therapy Framework" />
                                                <TableColumn fx:id="colDate" prefWidth="110.0" text="Payment Date" />
                                                <TableColumn fx:id="colAmount" prefWidth="130.0" text="Amount Paid (LKR)" />
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        </TableView>
                                    </children>
                                </AnchorPane>
                            </children>
                        </VBox>

                        <VBox maxWidth="380.0" minWidth="320.0" prefWidth="350.0" spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 13px;" text="🎯 Active Patient Session Verification" />
                                <AnchorPane VBox.vgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="tblPatientSessions" styleClass="clinical-table" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                            <columns>
                                                <TableColumn fx:id="colSessId" prefWidth="55.0" text="Sess ID" />
                                                <TableColumn fx:id="colSessDate" prefWidth="125.0" text="Date &amp; Time" />
                                                <TableColumn fx:id="colSessProgram" prefWidth="110.0" text="Program Context" />
                                                <TableColumn fx:id="colSessStatus" prefWidth="75.0" text="Status" />
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        </TableView>
                                    </children>
                                </AnchorPane>
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>