<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="380.0" prefWidth="500.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-background-radius: 8px;" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.CustomMessageModalController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Compose Custom Client Notification" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="Type message subject parameters and content bounds to dispatch via Gmail." />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="field-label" text="Email Subject Heading *" />
                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                            <children>
                                <FontIcon iconColor="#94A3B8" iconLiteral="fas-heading" iconSize="13" />
                                <TextField fx:id="txtSubject" prefHeight="38.0" promptText="Enter communication subject description reference..." styleClass="text-field-raw" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="field-label" text="Message Body Narrative *" />
                        <TextArea fx:id="txtMessageBody" prefHeight="150.0" promptText="Write customized greeting parameters, notification messages, or follow-up details here..." styleClass="text-area-raw" wrapText="true" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnCancel" onAction="#btnCancelOnAction" prefHeight="38.0" prefWidth="100.0" styleClass="btn-clear" text="Cancel" />
                        <Button fx:id="btnProceed" onAction="#btnProceedOnAction" prefHeight="38.0" prefWidth="150.0" styleClass="btn-save" text="Launch Composer">
                            <graphic>
                                <FontIcon iconColor="#FFFFFF" iconLiteral="fas-paper-plane" iconSize="13" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>